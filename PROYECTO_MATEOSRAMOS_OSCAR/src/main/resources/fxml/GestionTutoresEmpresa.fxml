<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.oscar.proyecto.controller.ControladorGestionTutoresEmpresa"
            fx:id="rootPane">

    <top>
        <HBox spacing="10" styleClass="header">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Label text="Gestión de Tutores de Empresa" styleClass="header-title"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15" styleClass="content-area">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <TableView fx:id="tablaTutores" prefHeight="400">
                <columns>
                    <TableColumn fx:id="colEmpresa" text="Empresa" prefWidth="150"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                    <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="120"/>
                    <TableColumn fx:id="colFechaIngreso" text="Fecha Ingreso" prefWidth="140"/>
                </columns>
            </TableView>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Añadir Tutor" fx:id="btnAñadir" styleClass="action-button"
                        onAction="#añadirTutor"/>

                <Button text="Editar Tutor" fx:id="btnEditar" styleClass="action-button"
                        onAction="#editarTutor"/>

                <Button text="Eliminar Tutor" fx:id="btnEliminar" styleClass="delete-button"
                        onAction="#eliminarTutor"/>

                <Button text="Volver" fx:id="btnVolver" styleClass="back-button"
                        onAction="#volverMenuAdmin"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>
