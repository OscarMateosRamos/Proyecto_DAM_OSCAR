<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.web.WebView?>
<?import javafx.scene.control.ListView?>
<?import javafx.geometry.Pos?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.oscar.proyecto.controller.ControladorAyuda"
            prefWidth="900">

    <top>
        <HBox alignment="TOP_RIGHT" spacing="10" style="-fx-padding: 10;">
            <Button text="Cerrar" onAction="#cerrarAyuda"/>
        </HBox>
    </top>

    <left>
        <ListView fx:id="listaTemas" prefWidth="200"/>
    </left>

    <center>
        <WebView fx:id="webViewAyuda" prefWidth="680" prefHeight="600"/>
    </center>

</BorderPane>