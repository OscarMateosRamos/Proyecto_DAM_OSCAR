<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.oscar.proyecto.controller.ControladorGestionCursos"
            fx:id="rootPane">

   
    <top>
        <HBox spacing="10" styleClass="header">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Label text="Gestión de Cursos" styleClass="header-title"/>
        </HBox>
    </top>

 
    <center>
        <VBox spacing="15" styleClass="content-area">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

          
            <TableView fx:id="tablaCursos" prefHeight="400">
                <columns>
                    <TableColumn fx:id="colCiclo" text="Ciclo" prefWidth="200"/>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="200"/>
                    <TableColumn fx:id="colCodigo" text="Código" prefWidth="120"/>
                    <TableColumn fx:id="colAnio" text="Año Académico" prefWidth="150"/>
                    <TableColumn fx:id="colProfesores" text="Profesores" prefWidth="300"/>
                </columns>
            </TableView>

        
            <HBox spacing="15" alignment="CENTER">
                <Button text="Añadir Curso" fx:id="btnAñadir" styleClass="action-button"
                        onAction="#añadirCurso"/>

                <Button text="Editar Curso" fx:id="btnEditar" styleClass="action-button"
                        onAction="#editarCurso"/>

                <Button text="Eliminar Curso" fx:id="btnEliminar" styleClass="delete-button"
                        onAction="#eliminarCurso"/>

                <Button text="Volver" fx:id="btnVolver" styleClass="back-button"
                        onAction="#volverMenuAdmin"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>
