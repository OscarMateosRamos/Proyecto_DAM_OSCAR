<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.oscar.proyecto.controller.ControladorGestionEstudiantes"
            fx:id="rootPane">

    <top>
        <HBox spacing="10" styleClass="header">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Label text="Gestión de Estudiantes" styleClass="header-title"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15" styleClass="content-area">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <TableView fx:id="tablaEstudiantes" prefHeight="400">
                <columns>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="150"/>
                    <TableColumn fx:id="colApellidos" text="Apellidos" prefWidth="200"/>
                    <TableColumn fx:id="colDni" text="DNI" prefWidth="120"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
                    <TableColumn fx:id="colGrupo" text="Grupo" prefWidth="150"/>
                </columns>
            </TableView>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Añadir Estudiante" styleClass="action-button"
                        onAction="#añadirEstudiante"/>

                <Button text="Editar Estudiante" styleClass="action-button"
                        onAction="#editarEstudiante"/>

                <Button text="Eliminar Estudiante" styleClass="delete-button"
                        onAction="#eliminarEstudiante"/>

                <Button text="Volver" styleClass="back-button"
                        onAction="#volverMenuAdmin"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
