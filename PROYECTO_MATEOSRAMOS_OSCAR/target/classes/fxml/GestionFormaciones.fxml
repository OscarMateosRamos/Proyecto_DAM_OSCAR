<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.oscar.proyecto.controller.ControladorGestionFormaciones"
            fx:id="rootPane">

    <top>
        <HBox spacing="10" styleClass="header">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Label text="Gestión de Formaciones" styleClass="header-title"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15" styleClass="content-area">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Buscar:"/>
                <TextField fx:id="txtBuscar" promptText="Estudiante, empresa..."
                           prefWidth="220"/>
                <Label text="Período:"/>
                <ComboBox fx:id="cboPeriodo" prefWidth="160"/>
            </HBox>

            <TableView fx:id="tablaFormaciones" prefHeight="400">
                <columns>
                    <TableColumn fx:id="colId"            text="ID"               prefWidth="55"/>
                    <TableColumn fx:id="colEstudiante"    text="Estudiante"        prefWidth="160"/>
                    <TableColumn fx:id="colEmpresa"       text="Empresa"           prefWidth="140"/>
                    <TableColumn fx:id="colTutorEmpresa"  text="Tutor empresa"     prefWidth="140"/>
                    <TableColumn fx:id="colProfesorCoord" text="Profesor coord."   prefWidth="140"/>
                    <TableColumn fx:id="colFechaInicio"   text="Fecha inicio"      prefWidth="110"/>
                    <TableColumn fx:id="colFechaFin"      text="Fecha fin"         prefWidth="110"/>
                    <TableColumn fx:id="colPeriodo"       text="Período"           prefWidth="110"/>
                </columns>
            </TableView>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Añadir formación"
                        fx:id="btnAñadir"
                        styleClass="action-button"
                        onAction="#añadirFormacion"/>
                <Button text="Editar formación"
                        fx:id="btnEditar"
                        styleClass="action-button"
                        onAction="#editarFormacion"/>
                <Button text="Eliminar formación"
                        fx:id="btnEliminar"
                        styleClass="delete-button"
                        onAction="#eliminarFormacion"/>
            </HBox>

            <Separator/>

            <HBox alignment="CENTER_RIGHT">
                <Button text="Volver"
                        fx:id="btnVolver"
                        styleClass="back-button"
                        onAction="#volverMenuAdmin"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>